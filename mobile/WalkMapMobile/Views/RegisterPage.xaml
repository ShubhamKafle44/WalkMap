<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WalkMapMobile.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F1923">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <Label Text="🚶" FontSize="64" HorizontalOptions="Center" Margin="0,0,0,8"/>
            <Label Text="Create Account"
                   FontSize="32" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" Margin="0,0,0,6"/>
            <Label Text="Start tracking your walks today"
                   FontSize="14" TextColor="#7A8FA6"
                   HorizontalOptions="Center" Margin="0,0,0,40"/>

            <!-- Username -->
            <Label Text="Username" TextColor="#7A8FA6" FontSize="12" Margin="0,0,0,6"/>
            <Border Stroke="#1E2D3D" StrokeThickness="1" BackgroundColor="#172130"
                    StrokeShape="RoundRectangle 12" Padding="16,0" Margin="0,0,0,16">
                <Entry Text="{Binding Username}" Placeholder="johndoe"
                       PlaceholderColor="#3A4F63" TextColor="White"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Email -->
            <Label Text="Email" TextColor="#7A8FA6" FontSize="12" Margin="0,0,0,6"/>
            <Border Stroke="#1E2D3D" StrokeThickness="1" BackgroundColor="#172130"
                    StrokeShape="RoundRectangle 12" Padding="16,0" Margin="0,0,0,16">
                <Entry Text="{Binding Email}" Placeholder="you@example.com"
                       PlaceholderColor="#3A4F63" TextColor="White"
                       Keyboard="Email" BackgroundColor="Transparent"/>
            </Border>

            <!-- Password -->
            <Label Text="Password" TextColor="#7A8FA6" FontSize="12" Margin="0,0,0,6"/>
            <Border Stroke="#1E2D3D" StrokeThickness="1" BackgroundColor="#172130"
                    StrokeShape="RoundRectangle 12" Padding="16,0" Margin="0,0,0,16">
                <Entry Text="{Binding Password}" Placeholder="••••••••"
                       PlaceholderColor="#3A4F63" TextColor="White"
                       IsPassword="True" BackgroundColor="Transparent"/>
            </Border>

            <!-- Confirm Password -->
            <Label Text="Confirm Password" TextColor="#7A8FA6" FontSize="12" Margin="0,0,0,6"/>
            <Border Stroke="#1E2D3D" StrokeThickness="1" BackgroundColor="#172130"
                    StrokeShape="RoundRectangle 12" Padding="16,0" Margin="0,0,0,8">
                <Entry Text="{Binding ConfirmPassword}" Placeholder="••••••••"
                       PlaceholderColor="#3A4F63" TextColor="White"
                       IsPassword="True" BackgroundColor="Transparent"/>
            </Border>

            <Label Text="{Binding ErrorMessage}" TextColor="#FF6B6B" FontSize="13"
                   IsVisible="{Binding HasError}" Margin="0,0,0,16"/>

            <Button Text="Create Account"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                    BackgroundColor="#4CAF50" TextColor="White"
                    FontAttributes="Bold" CornerRadius="12"
                    HeightRequest="52" Margin="0,8,0,0"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#4CAF50" Margin="0,12,0,0"/>

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,24,0,0" Spacing="4">
                <Label Text="Already have an account?" TextColor="#7A8FA6" FontSize="14"/>
                <Label Text="Sign in" TextColor="#4CAF50" FontSize="14" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
