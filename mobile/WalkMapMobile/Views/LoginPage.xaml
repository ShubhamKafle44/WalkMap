<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WalkMapMobile.ViewModels"
             x:Class="WalkMapMobile.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F1923">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Logo / Hero -->
            <Label Text="🚶" FontSize="64" HorizontalOptions="Center" Margin="0,0,0,8"/>
            <Label Text="WalkMap"
                   FontSize="36" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>
            <Label Text="Track every step of your journey"
                   FontSize="14" TextColor="#7A8FA6"
                   HorizontalOptions="Center" Margin="0,4,0,48"/>

            <!-- Email -->
            <Label Text="Email" TextColor="#7A8FA6" FontSize="12" Margin="0,0,0,6"/>
            <Border Stroke="#1E2D3D" StrokeThickness="1" BackgroundColor="#172130"
                    StrokeShape="RoundRectangle 12" Padding="16,0" Margin="0,0,0,16">
                <Entry Text="{Binding Email}"
                       Placeholder="you@example.com"
                       PlaceholderColor="#3A4F63"
                       TextColor="White"
                       Keyboard="Email"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Password -->
            <Label Text="Password" TextColor="#7A8FA6" FontSize="12" Margin="0,0,0,6"/>
            <Border Stroke="#1E2D3D" StrokeThickness="1" BackgroundColor="#172130"
                    StrokeShape="RoundRectangle 12" Padding="16,0" Margin="0,0,0,8">
                <Entry Text="{Binding Password}"
                       Placeholder="••••••••"
                       PlaceholderColor="#3A4F63"
                       TextColor="White"
                       IsPassword="True"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#FF6B6B"
                   FontSize="13"
                   IsVisible="{Binding HasError}"
                   Margin="0,0,0,16"/>

            <!-- Login Button -->
            <Button Text="Sign In"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="52"
                    Margin="0,8,0,0"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#4CAF50"
                               Margin="0,12,0,0"/>

            <!-- Register Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,24,0,0" Spacing="4">
                <Label Text="Don't have an account?" TextColor="#7A8FA6" FontSize="14"/>
                <Label Text="Sign up"
                       TextColor="#4CAF50"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
