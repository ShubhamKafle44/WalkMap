<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="WalkMapMobile.Views.GenerateRoutePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F1923">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,52,20,16"
              ColumnDefinitions="Auto,*"
              BackgroundColor="#0F1923">
            <Button Grid.Column="0"
                    Text="←"
                    Command="{Binding BackCommand}"
                    BackgroundColor="#172130"
                    TextColor="White"
                    CornerRadius="20"
                    WidthRequest="40" HeightRequest="40"
                    Padding="0"/>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="Generate Route" FontSize="20"
                       FontAttributes="Bold" TextColor="White"
                       HorizontalOptions="Center"/>
                <Label Text="Circular route from your location"
                       FontSize="12" TextColor="#7A8FA6"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Map -->
        <maps:Map x:Name="RouteMap"
                  Grid.Row="1"
                  MapType="Street"
                  IsShowingUser="True"/>

        <!-- Controls -->
        <VerticalStackLayout Grid.Row="2" Padding="20,16,20,40" Spacing="12"
                             BackgroundColor="#0F1923">

            <!-- Distance Slider -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding TargetDistanceKm, StringFormat='Target: {0:F1} km'}"
                       TextColor="White" FontSize="15" FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="1–10 km" TextColor="#7A8FA6" FontSize="12"
                       VerticalOptions="Center"/>
            </Grid>

            <Slider Minimum="0.5" Maximum="10"
                    Value="{Binding TargetDistanceKm}"
                    ThumbColor="#4CAF50"
                    MinimumTrackColor="#4CAF50"
                    MaximumTrackColor="#1E2D3D"/>

            <!-- Result text -->
            <Label Text="{Binding ResultText}"
                   TextColor="#4CAF50" FontSize="13"
                   IsVisible="{Binding HasRoute}"
                   HorizontalOptions="Center"/>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="#FF6B6B" FontSize="13"
                   IsVisible="{Binding HasError}"
                   HorizontalOptions="Center"/>

            <Button Text="Generate Route 🗺️"
                    Command="{Binding GenerateCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="52"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#4CAF50"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
