<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:WalkMapMobile.Converters"
             x:Class="WalkMapMobile.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Converters available across all XAML pages -->
            <converters:InvertBoolConverter x:Key="InvertBool"/>

            <!-- Global color palette -->
            <Color x:Key="AppBg">#0F1923</Color>
            <Color x:Key="CardBg">#172130</Color>
            <Color x:Key="Border">#1E2D3D</Color>
            <Color x:Key="AccentGreen">#4CAF50</Color>
            <Color x:Key="TextPrimary">White</Color>
            <Color x:Key="TextMuted">#7A8FA6</Color>
            <Color x:Key="DangerRed">#FF4444</Color>

        </ResourceDictionary>
    </Application.Resources>

</Application>
