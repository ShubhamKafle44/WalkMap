@page "/walk/{Id:int}/end"
@inject WalkService WalkService
@inject NavigationManager Nav

<PageTitle>End Walk – WalkMap</PageTitle>

<div class="page-head">
    <div>
        <a class="back-link" href="/walks">← Walks</a>
        <h1>End Walk</h1>
        <p>Record your final stats</p>
    </div>
</div>

<div class="form-card">
    @if (error != "") { <div class="form-error">@error</div> }

    <div class="field">
        <label>Step Count</label>
        <input type="number" @bind="steps" min="0" placeholder="e.g. 5000" />
    </div>

    <div class="field-row-head">
        <label>Route Points</label>
        <button class="btn-sm" @onclick="AddPt">+ Add</button>
    </div>

    @if (pts.Any())
    {
        @for (int i = 0; i < pts.Count; i++)
        {
            var idx = i;
            <div class="pt-row">
                <span class="pt-idx">@(idx + 1)</span>
                <input type="number" class="pt-in" @bind="pts[idx].Latitude" step="0.000001" placeholder="Lat" />
                <input type="number" class="pt-in" @bind="pts[idx].Longitude" step="0.000001" placeholder="Lng" />
                <button class="del-btn" @onclick="() => pts.RemoveAt(idx)">✕</button>
            </div>
        }
    }
    else
    {
        <p class="muted">No points — you can end without them.</p>
    }

    <div class="form-actions">
        <a href="/walks" class="btn-ghost">Cancel</a>
        <button class="btn-primary" @onclick="Submit" disabled="@busy">
            @if (busy) { <span class="spin"></span> } else { <span>End Walk</span> }
        </button>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    int steps;
    List<WalkPointDto> pts = new();
    string error = "";
    bool busy;

    void AddPt() => pts.Add(new() { Timestamp = DateTime.UtcNow, SequenceOrder = pts.Count + 1 });

    async Task Submit()
    {
        busy = true; error = "";
        try
        {
            var r = await WalkService.EndAsync(Id, new() { StepCount = steps, RoutePoints = pts });
            if (r != null) Nav.NavigateTo("/walks/" + r.Id);
        }
        catch (Exception ex) { error = ex.Message; }
        busy = false;
    }
}
