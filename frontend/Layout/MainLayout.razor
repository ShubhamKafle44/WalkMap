@inherits LayoutComponentBase
@inject AuthStateService Auth
@inject NavigationManager Nav
@implements IDisposable

@if (Auth.IsAuthenticated)
{
    <div class="shell">
        <nav class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-mark">W</div>
                <span>WalkMap</span>
            </div>
            <div class="nav-group">
                <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                    Dashboard
                </NavLink>
                <NavLink href="/walks" class="nav-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    My Walks
                </NavLink>
                <NavLink href="/walk/start" class="nav-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10,8 16,12 10,16"/></svg>
                    Start Walk
                </NavLink>
                <NavLink href="/route/generate" class="nav-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                    Generate Route
                </NavLink>
            </div>
            <div class="sidebar-foot">
                <div class="avatar">@(Auth.Username?.Length > 0 ? Auth.Username[0].ToString().ToUpper() : "?")</div>
                <div class="user-meta">
                    <div class="user-name">@Auth.Username</div>
                    <div class="user-email">@Auth.Email</div>
                </div>
                <button class="logout-btn" @onclick="Logout" title="Sign out">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                </button>
            </div>
        </nav>
        <main class="content">
            @Body
        </main>
    </div>
}
else
{
    <div class="auth-shell">
        @Body
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        Auth.OnChange += StateHasChanged;
        if (!Auth.IsAuthenticated)
            Nav.NavigateTo("/login");
    }

    async Task Logout()
    {
        await Auth.ClearAsync();
        Nav.NavigateTo("/login");
    }

    public void Dispose() => Auth.OnChange -= StateHasChanged;
}
